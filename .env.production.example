# MealScout Production Environment (Render Backend)
# Copy to Render dashboard as environment variables

# Core Settings
NODE_ENV=production
PORT=5001
BETA_MODE=true

# Database (Neon PostgreSQL - same for dev and prod)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Security Secrets (GENERATE NEW VALUES FOR PRODUCTION)
SESSION_SECRET=<GENERATE_RANDOM_64_CHAR_STRING>
INCIDENT_SIGNATURE_SECRET=<GENERATE_RANDOM_64_CHAR_STRING>

# TradeScout Integration
TRADESCOUT_API_TOKEN=<REPLACE_WITH_PRODUCTION_TOKEN>

# CORS Origins (Production Frontend)
CLIENT_ORIGIN=https://mealscout.us
ALLOWED_ORIGINS=https://mealscout.us,https://www.mealscout.us,https://thetradescout.com,https://www.thetradescout.com

# Public URL (Render Backend Subdomain)
PUBLIC_BASE_URL=https://api.mealscout.thetradescout.com
# Canonical website origin for sitemap/robots output
SITEMAP_SITE_URL=https://www.mealscout.us

# Email Configuration (Optional - for password reset)
BREVO_API_KEY=

# OAuth (Optional - if enabling Google/Facebook login later)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
