# ===== CRITICAL - REQUIRED FOR ALL DEPLOYMENTS =====
# Database Configuration
DATABASE_URL=your_postgresql_connection_string

# Session Configuration
SESSION_SECRET=your_secure_session_secret_key_min_32_chars

# Client origin (used by server env validation)
CLIENT_ORIGIN=https://mealscout.us

# CORS Configuration - comma-separated origins (REQUIRED in production)
# Examples:
# ALLOWED_ORIGINS=https://mealscout.us,https://app.mealscout.us
# ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000
ALLOWED_ORIGINS=https://mealscout.us,http://localhost:5000,http://localhost:5200,http://127.0.0.1:5200

# ===== OPTIONAL - TRADESCOUT LLM INTEGRATION =====
# API Token for TradeScout LLM to call MealScout actions
# Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
TRADESCOUT_API_TOKEN=your_secure_token_for_tradescout_llm

# ===== OPTIONAL - BETA/TESTING =====
# Beta Mode - set to 'true' to enable free access for all users
# Default: false (NOT recommended for production)
BETA_MODE=false
MEALSCOUT_TEST_MODE=false
MEALSCOUT_BYPASS_STRIPE=false

# Client UI helper: show testing-only promo inputs (DEV also shows these automatically)
VITE_SHOW_TEST_PROMOS=false

# Booking promo: allow BOOKFEE10 in production (disabled by default)
BOOKFEE10_ENABLED=false

# API logging controls (production defaults: only 5xx or slow responses)
API_LOG_VERBOSE=false
API_LOG_SLOW_MS=1500

# Map feed hardening (avoid watchdog timeouts when geocoding is slow)
MAP_LOCATIONS_CACHE_TTL_MS=300000
MAP_LOCATIONS_MAX_GEOCODE=5
MAP_LOCATIONS_GEOCODE_BUDGET_MS=1500
MAP_LOCATIONS_GEOCODE_TIMEOUT_MS=750
MAP_LOCATIONS_MAX_REVERSE_GEOCODE=2
MAP_LOCATIONS_MAX_COORD_MISMATCH_FIXES=0

# ===== OPTIONAL - AUTHENTICATION =====
# Social Media OAuth (Optional)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
REQUIRE_PHONE_VERIFICATION=true
VITE_REQUIRE_PHONE_VERIFICATION=true

# ===== OPTIONAL - BREVO (EMAIL/SMS/CRM) =====
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=notifications@mealscout.us
EMAIL_FROM_NAME=MealScout
BREVO_SMS_SENDER=MealScout
BREVO_LIST_CUSTOMER_ID=
BREVO_LIST_RESTAURANT_OWNER_ID=
BREVO_LIST_FOOD_TRUCK_ID=
BREVO_LIST_HOST_ID=
BREVO_LIST_EVENT_COORDINATOR_ID=

# ===== OPTIONAL - PAYMENTS =====
# Stripe Configuration (Optional - required for subscription and booking payment features)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret
STRIPE_WEBHOOK_FORCE_VERIFY=false
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
PRICE_MONTHLY_25=price_123
PRICE_MONTHLY_50=price_456

# ===== OPTIONAL - PENSACOLA LEAD MAGNET / DRIP =====
# Controls the public lead-magnet page at /pensacola/spots
PENSACOLA_LEAD_LOCATIONS_LIMIT=20
# Enables the automated drip sequence for verified food truck users with Pensacola truck profiles.
PENSACOLA_FOOD_TRUCK_DRIP_ENABLED=false
PENSACOLA_FOOD_TRUCK_DRIP_LOOKBACK_DAYS=30

# Pensacola report (email capture + PDF download + drip follow-ups)
PENSACOLA_REPORT_ENABLED=false
PENSACOLA_REPORT_LOOKBACK_DAYS=30
REPORT_DOWNLOAD_TOKEN_TTL_HOURS=72
REPORT_EMAIL_COOLDOWN_MINUTES=30

# ===== OPTIONAL - ERROR TRACKING =====
SENTRY_DSN=

# ===== OPTIONAL - SESSION CLEANUP =====
# Set to "false" to disable background cleanup.
SESSION_CLEANUP_ENABLED=true

# ===== OPTIONAL - ADMIN =====
# Admin Account
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=secure_admin_password

# ===== OPTIONAL - DATABASE DETAILS =====
# PostgreSQL Connection Details (alternative to DATABASE_URL)
PGHOST=your_db_host
PGPORT=5432
PGUSER=your_db_user
PGPASSWORD=your_db_password
PGDATABASE=your_db_name

# ===== INCIDENT MANAGEMENT (SOC-LITE) =====
# Cryptographic signing for incident integrity
INCIDENT_SIGNATURE_SECRET=your_incident_hmac_secret_change_in_production_min_32_chars

# Notification channels
INCIDENT_EMAIL_RECIPIENTS=admin@mealscout.us,security@mealscout.us
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
INCIDENT_SMS_RECIPIENTS=+15551234567,+15557654321

# Email configuration (choose one)
SENDGRID_API_KEY=SG.xxxxx
# OR use SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@mealscout.us
SMTP_PASS=your_smtp_password

# SMS configuration (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15551234567

# Escalation timing (in minutes)
INCIDENT_ESCALATION_NO_ACK_MINUTES=15
INCIDENT_ESCALATION_NO_RESOLUTION_MINUTES=120
INCIDENT_ESCALATION_BREACH_MINUTES=1440
INCIDENT_ESCALATION_HARD_MINUTES=4320

# On-call configuration
ONCALL_ROTATION_MODE=weekly
ONCALL_DEFAULT_CONTACT_EMAIL=security@mealscout.us

# ===== DEPLOYMENT =====
# Production Settings
NODE_ENV=production
PORT=5000
PUBLIC_BASE_URL=https://mealscout.us
# Optional canonical site origin used by /sitemap.xml and /robots.txt generation
SITEMAP_SITE_URL=https://www.mealscout.us

# Development-only: NEVER enable in production. This seeds fake demo restaurants/deals for local testing.
# Requires NODE_ENV=development.
SEED_DEV_DATA=false
