{
  "installCommand": "npm ci",
  "buildCommand": "npm --prefix client run build",
  "outputDirectory": "client/dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "mealscout.us" }],
      "destination": "https://www.mealscout.us/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://mealscout.onrender.com/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://mealscout.onrender.com/robots.txt"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://mealscout.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
